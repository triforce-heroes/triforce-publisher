{
  "name": "@triforce-heroes/triforce-publisher",
  "version": "2.0.0",
  "description": "Project entries generator for TAPP.",
  "license": "Apache License 2.0",
  "files": [
    "dist"
  ],
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "rimraf ./dist && tspc -p ./tsconfig.build.json && swc ./dist -d .",
    "typecheck": "tsc --noEmit",
    "lint": "npm run typecheck && npm run eslint && npm run oxfmt",
    "lint:fix": "npm run typecheck && npm run eslint:fix && npm run oxfmt:fix",
    "oxfmt": "oxfmt --check ./src ./tests ./*.mjs ./*.json",
    "oxfmt:fix": "oxfmt --write ./src ./tests ./*.mjs ./*.json",
    "eslint": "eslint ./src ./tests ./*.mjs",
    "eslint:fix": "eslint --fix ./src ./tests ./*.mjs",
    "test": "vitest --run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@rheactor/rheactor-query-builder": "github:rheactor/rheactor-query-builder"
  },
  "devDependencies": {
    "@rheactor/eslint-config-rheactor": "github:rheactor/eslint-config-rheactor",
    "@swc/cli": "^0.8.1",
    "@swc/core": "^1.15.43",
    "@types/node": "^26.0.1",
    "eslint": "^10.6.0",
    "oxfmt": "^0.56.0",
    "rimraf": "^6.1.3",
    "ts-patch": "^4.0.1",
    "typescript": "^6.0.3",
    "typescript-transform-paths": "^4.0.0",
    "vitest": "^4.1.9"
  }
}
